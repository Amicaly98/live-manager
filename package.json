{"name":"bilibili-live-manager","version":"1.0.0","description":"直播控制系统 - 一站式桌面直播管理工具","main":"dist-electron/main.js","scripts":{"dev:backend":"cd backend && python run.py --reload","dev:frontend":"cd frontend && npm run dev","build:electron-ts":"tsc -p electron/tsconfig.json","build:icons":"node scripts/generate-icons.mjs","dev:electron":"npm run build:electron-ts && concurrently -n vite,electron \"npm run dev:frontend\" \"wait-on http://localhost:5173 && electron . --dev\"","build:frontend":"cd frontend && npm run build","build:electron":"npm run build:electron-ts && npm run build:icons && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder","build":"npm run build:frontend && npm run build:electron","lint":"cd frontend && npm run lint","format":"cd frontend && npm run format"},"keywords":["bilibili","live","stream","electron","vue"],"author":"Bilibili Live Manager","license":"MIT","devDependencies":{"concurrently":"^9.2.1","cross-env":"^10.1.0","electron":"^28.0.0","electron-builder":"^24.9.0","sharp":"^0.34.5","typescript":"^5.3.0","wait-on":"^9.0.5"},"build":{"appId":"com.bilibili.live-manager","productName":"直播控制系统","directories":{"output":"release"},"files":["dist-electron/**/*","frontend/dist/**/*","assets/**/*"],"extraResources":[{"from":"backend","to":"backend","filter":["**/*","!__pycache__/**","!*.pyc","!*.log","!*.db","!*.xlsx","!*.json","!bili_cookies.json","!_temp_*"]}],"win":{"target":["nsis","portable"],"icon":"assets/icon.ico","sign":null},"mac":{"target":["dmg"],"icon":"assets/icon.icns"},"nsis":{"oneClick":false,"allowToChangeInstallationDirectory":true,"createDesktopShortcut":true},"publish":{"provider":"github","owner":"your-github-username","repo":"bilibili-live-manager"},"electronDownload":{"mirror":"https://npmmirror.com/mirrors/electron/"},"electronDist":"node_modules/electron/dist"},"dependencies":{"electron-updater":"^6.8.3"}}